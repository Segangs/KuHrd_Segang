{
    "C_Cpp.errorSquiggles": "disabled",
    "locale": "ko",

    // 빌드 출력 폴더 위치 (기본값: ${workspaceFolder}/build)
    "cmake.buildDirectory": "${workspaceFolder}/build",

    // 현재 cpp_code 폴더 외의 워크스페이스 항목 숨김
