        "CMakeLists.txt": true,
        "CMakeLists2.txt": true,
        "CMake사용법.md": true,
    //    "HonGong_Practice/": true,
        "LICENSE": true,
    //    "README.md": true,
        "atmega128/": true,
        "build/": true,
        "dataStructure/": true,
        "pico/": true,
   //     ".vscode/": true
    },

    "git.autofetch": true,

